# Off-Grid Scout API Configuration
# Copy this file to .env and fill in your values

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=*

# Email (SMTP) - leave blank to use demo mode
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Logging level
LOG_LEVEL=INFO

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_SCOUT=price_xxx
STRIPE_PRICE_PIONEER=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx
FRONTEND_URL=https://your-app.onrender.com

# Database
DATABASE_PATH=offgridscout.db

# Admin Dashboard
ADMIN_KEY=change-me-to-a-secure-random-string
