{
  "manifest_version": 3,
  "name": "Off-Grid Scout",
  "version": "1.0.0",
  "description": "AI-powered UK land evaluation for off-grid living. Instantly analyse any property listing for sovereignty potential.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.rightmove.co.uk/*",
    "https://www.zoopla.co.uk/*",
    "https://www.onthemarket.com/*",
    "https://search.savills.com/*",
    "https://www.primelocation.com/*",
    "https://www.plotfinder.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.rightmove.co.uk/properties/*",
        "https://www.zoopla.co.uk/for-sale/details/*",
        "https://www.onthemarket.com/details/*",
        "https://search.savills.com/property-detail/*",
        "https://www.primelocation.com/for-sale/*",
        "https://www.plotfinder.net/plots/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
